# geniusDebug — environment example. Copy to .env (never commit .env).
# Golden rule: secrets are server-side only; the public DSN key is write-only.

# --- Datastores (geniusDebug runs on its OWN infra, isolated from Taskip — NFR-PERF-5) ---
DATABASE_URL=postgres://sharifur@localhost:5432/geniusdebug_dev
REDIS_URL=redis://localhost:6379

# --- Ports ---
INGEST_PORT=4001
API_PORT=4002
WEB_PORT=5173

# --- Auth (dashboard) ---
JWT_SECRET=dev-only-change-me-in-prod
JWT_EXPIRES_IN=7d

# --- Ingest limits (FR-ING-2/4) ---
INGEST_RATE_LIMIT_PER_MIN=3000
MAX_EVENT_ITEM_BYTES=1048576
MAX_ENVELOPE_BYTES=209715200

# --- Cloudflare R2 (blobs: replay, source maps) — server-side only (NFR-SEC-5) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=geniusdebug-blobs
R2_ENDPOINT=

# --- AWS SES (email alerts) — server-side only ---
SES_REGION=us-east-1
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SES_FROM=alerts@geniusdebug.local

# --- GitHub App (source links) — server-side only ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- Web (public; Vite) ---
VITE_API_URL=http://localhost:4002
